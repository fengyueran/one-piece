{
  "name": "@xinghunm/ai-chat",
  "version": "0.1.0",
  "description": "AI chat React component library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@xinghunm/compass-ui": ">=0.8.0",
    "axios": ">=1.0",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=9",
    "rehype-katex": ">=7",
    "remark-gfm": ">=4",
    "remark-math": ">=6",
    "zustand": ">=5"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.5",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.22",
    "@types/react-dom": "^18.2.7",
    "@xinghunm/compass-ui": "workspace:^",
    "axios": "^1.9.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.2.2",
    "zustand": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
